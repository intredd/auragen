{
  "name": "gradient-gen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Live gradient generator — animated WebGL blobs with export to image/video.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:embed": "vite build --config vite.lib.config.ts",
    "build:all": "npm run build && npm run build:embed",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
